# Use OpenRouter (Anthropic Messages API) — set this OR ANTHROPIC_API_KEY
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Direct Anthropic API (leave OPENROUTER_API_KEY unset)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — only used with OpenRouter; SDK base must stay https://openrouter.ai/api
# ANTHROPIC_BASE_URL=https://openrouter.ai/api
# OPENROUTER_HTTP_REFERER=https://yoursite.example
# OPENROUTER_APP_TITLE=opus-benchmark

# Override model slugs if OpenRouter renames them (defaults pick OpenRouter vs direct from keys above)
# MODEL_OPUS_4_7=anthropic/claude-opus-4-7
# MODEL_OPUS_4_6=anthropic/claude-opus-4-6

RESULTS_DIR=./results

# HTTP read timeout per request (seconds); required for large max_tokens without streaming
# BENCHMARK_HTTP_TIMEOUT_S=3600
